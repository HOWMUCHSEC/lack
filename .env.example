# Lack environment example
# Copy to .env for local development. Never commit real credentials.

# Optional backend Supabase evaluator integration.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional backend Sentry telemetry. Leave empty to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional Nuclei template development switches.
# Production builds use the embedded AI/LLM template set by default.
LACK_NUCLEI_TEMPLATES_DIR=
LACK_NUCLEI_ALLOW_EXTERNAL_TEMPLATES=0
LACK_NUCLEI_TEMPLATE_FILTER_MODE=ai-llm

# Optional update client timeout override.
LACK_UPDATE_TIMEOUT_SECONDS=30
