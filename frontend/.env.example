# Lack frontend environment example
# Copy to .env.local for local Vite development. Never commit real credentials.

# Optional frontend Supabase integration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional frontend Sentry telemetry. Leave empty to disable.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional build metadata. The Makefile sets these during release builds.
VITE_APP_VERSION=dev
VITE_EDITION=enterprise
